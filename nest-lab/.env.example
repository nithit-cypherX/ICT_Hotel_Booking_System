# =========================================================================
# Hotel Booking REST API — Environment Variable Template
# -------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values.
#     cp .env.example .env
# NEVER commit the real `.env` file to version control.
# =========================================================================

# ---- Application --------------------------------------------------------
NODE_ENV=development
PORT=3000

# ---- Database (MySQL via Prisma) ----------------------------------------
# Local dev (docker-compose):   mysql://hoteluser:hotelpass@mysql:3306/ICTHotel
# Uni-server deployment:        mysql://hoteluser:hotelpass@mysql:3306/ICTHotel
DATABASE_URL="mysql://hoteluser:hotelpass@mysql:3306/ICTHotel"

# MySQL container credentials (used by docker-compose mysql service)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=ICTHotel
MYSQL_USER=hoteluser
MYSQL_PASSWORD=hotelpass

# ---- Redis (caching + rate limiting) ------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ---- JWT Authentication -------------------------------------------------
# MUST be a long random string. App will FAIL TO START if this is not set.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=replace-this-with-a-long-random-secret-at-least-16-chars
JWT_EXPIRES_IN=1d

